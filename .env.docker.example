# Copy this file to .env.docker before running docker compose.

NODE_ENV=production

# REQUIRED: use a long random string in production.
AUTH_SECRET=replace-with-very-long-random-secret

# Optional host port override (default in compose is 43871)
APP_PORT=43871

# Storage + database
DATABASE_URL=file:/app/data/prod.db

S3_REGION=us-east-1
S3_BUCKET=replace-with-bucket
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
S3_ENDPOINT=https://s3.amazonaws.com
S3_PUBLIC_BASE_URL=https://replace-with-public-media-base-url
